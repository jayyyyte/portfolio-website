---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { featuredProjects } from "../data/projects";
import { getCollection } from "astro:content";

const caseStudies = await getCollection("case-studies");
---

<BaseLayout>
  <section class="border-b border-line bg-surface">
    <div class="mx-auto max-w-6xl px-5 py-16 lg:px-8 lg:py-20">
      <div class="grid gap-8 border border-line bg-white p-5 md:grid-cols-[0.95fr_1.05fr] md:p-6 lg:gap-10 lg:p-8">
        <figure class="flex min-h-[320px] items-center justify-center border border-line bg-surface p-4 md:min-h-[500px]">
          {profile.image ? (
            <img class="h-full max-h-[560px] w-full object-cover" src={profile.image} alt={`${profile.name} profile photo`} />
          ) : (
            <div class="flex aspect-[4/5] w-full items-center justify-center border border-dashed border-line bg-white text-sm font-semibold uppercase tracking-normal text-muted">
              Profile Image
            </div>
          )}
        </figure>

        <div class="flex flex-col justify-center">
          <p class="text-sm font-semibold uppercase tracking-normal text-accent">{profile.role}</p>
          <h1 class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-ink sm:text-4xl">
            {profile.name}
          </h1>
          <p class="mt-4 max-w-2xl leading-7 text-muted">{profile.about}</p>

          <aside class="mt-7 border border-line bg-surface p-5">
            <h2 class="text-sm font-semibold uppercase tracking-normal text-muted">Profile</h2>
            <dl class="mt-4 grid gap-4 text-sm sm:grid-cols-2">
              <div>
                <dt class="font-semibold text-ink">Location</dt>
                <dd class="mt-1 text-muted">{profile.location}</dd>
              </div>
              <div>
                <dt class="font-semibold text-ink">Focus</dt>
                <dd class="mt-1 text-muted">ETL/ELT, SQL, data modeling, orchestration, data quality</dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="font-semibold text-ink">Links</dt>
                <dd class="mt-1 flex flex-wrap gap-3 text-accent">
                  <a href={profile.github}>GitHub</a>
                  <a href={profile.linkedin}>LinkedIn</a>
                  <a href={`mailto:${profile.email}`}>Email</a>
                </dd>
              </div>
            </dl>
          </aside>

          <div class="mt-8 flex flex-wrap gap-3">
            <a class="border border-accent bg-accent px-4 py-2 text-sm font-semibold text-white hover:bg-white hover:text-accent" href="/projects/">
              View Projects
            </a>
            <a class="border border-line bg-white px-4 py-2 text-sm font-semibold text-ink hover:border-accent hover:text-accent" href="/case-studies/">
              Read Case Studies
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-14 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-normal text-accent">Skills</p>
      <h2 class="mt-2 text-2xl font-semibold text-ink">Data engineering fundamentals</h2>
      <p class="mt-3 leading-7 text-muted">Grouped skills make it easy to scan the stack used across pipeline, modeling, and reliability work.</p>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {profile.skills.map((group) => (
        <section class="border border-line bg-white p-5">
          <h3 class="font-semibold text-ink">{group.category}</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <span class="border border-line bg-surface px-3 py-1 text-sm text-muted">{skill}</span>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="border-y border-line bg-surface">
    <div class="mx-auto max-w-6xl px-5 py-14 lg:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-normal text-accent">Projects</p>
          <h2 class="mt-2 text-2xl font-semibold text-ink">Featured data engineering projects</h2>
        </div>
        <a class="text-sm font-semibold text-accent hover:underline" href="/projects/">View all projects</a>
      </div>
      <div class="mt-8 grid gap-5 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <article class="flex flex-col border border-line bg-white p-5">
            <div class="mb-4 flex items-center justify-between gap-3">
              <h3 class="text-lg font-semibold text-ink">{project.name}</h3>
              <span class="shrink-0 border border-line bg-surface px-2 py-1 text-xs font-medium text-muted">{project.status}</span>
            </div>
            <p class="leading-7 text-muted">{project.summary}</p>
            <p class="mt-4 text-sm font-semibold text-ink">Stack</p>
            <p class="mt-1 text-sm leading-6 text-muted">{project.techStack.join(", ")}</p>
            <a class="mt-5 text-sm font-semibold text-accent hover:underline" href={project.caseStudy}>Read case study</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-14 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-normal text-accent">Case Studies</p>
        <h2 class="mt-2 text-2xl font-semibold text-ink">Technical writeups</h2>
      </div>
      <a class="text-sm font-semibold text-accent hover:underline" href="/case-studies/">View case studies</a>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {caseStudies.map((entry) => (
        <a class="border border-line bg-white p-5 hover:border-accent" href={`/case-studies/${entry.slug}/`}>
          <span class="text-xs font-semibold uppercase tracking-normal text-muted">{entry.data.status}</span>
          <h3 class="mt-2 font-semibold text-ink">{entry.data.title}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{entry.data.summary}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
