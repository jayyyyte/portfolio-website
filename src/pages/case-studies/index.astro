---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const caseStudies = await getCollection("case-studies");
---

<BaseLayout title="Case Studies | Data Engineer Portfolio">
  <section class="border-b border-line bg-surface">
    <div class="mx-auto max-w-6xl px-5 py-12 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-normal text-accent">Case Studies</p>
      <h1 class="mt-2 text-3xl font-semibold text-ink sm:text-4xl">Pipeline and data modeling writeups</h1>
      <p class="mt-4 max-w-3xl leading-7 text-muted">
        Case studies explain the engineering problem, pipeline architecture, data model, quality checks, trade-offs, and outcomes.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-12 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {caseStudies.map((entry) => (
        <article class="border border-line bg-white p-5">
          <span class="text-xs font-semibold uppercase tracking-normal text-muted">{entry.data.status}</span>
          <h2 class="mt-2 text-xl font-semibold text-ink">{entry.data.title}</h2>
          <p class="mt-3 text-sm leading-6 text-muted">{entry.data.summary}</p>
          <p class="mt-4 text-sm font-semibold text-ink">Stack</p>
          <p class="mt-1 text-sm leading-6 text-muted">{entry.data.techStack.join(", ")}</p>
          <a class="mt-5 inline-block text-sm font-semibold text-accent hover:underline" href={`/case-studies/${entry.slug}/`}>
            Read case study
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
